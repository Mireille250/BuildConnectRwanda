{
  "name": "buildconnect-rwanda",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "build:all": "npm run build --workspaces",
    "lint:all": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}